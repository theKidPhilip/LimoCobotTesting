<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Matte dark chassis -->
    <material name="chassis_dark">
        <color rgba="0.15 0.15 0.15 1" />
    </material>

    <!-- Metallic silver (wheel hubs, bolts) -->
    <material name="metal_silver">
        <color rgba="0.7 0.7 0.7 1" />
    </material>

    <!-- Rubber black (tires) -->
    <material name="rubber_black">
        <color rgba="0.05 0.05 0.05 1" />
    </material>

    <!-- LIMO blue accent -->
    <material name="limo_blue">
        <color rgba="0.1 0.2 0.8 1" />
    </material>

    <!-- Sensor housing (LiDAR top cap) -->
    <material name="sensor_black">
        <color rgba="0.1 0.1 0.1 1" />
    </material>

    <!-- Transparent / debug -->
    <material name="transparent">
        <color rgba="0 0 0 0" />
    </material>

</robot>