<?xml version="1.0"?>
<!--
File: blazerbot_core.xacro
Project: Blazerbot Description (CS353 Lab 3)
Author: Zabdiel Addo
Version: 1.0.2
Brief: Core robot model. base_footprint added for Nav2/AMCL/SLAM compatibility.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="BLAZERBOT_PACKAGE_NAME" value="blazerbot_description" />

    <xacro:include filename="$(find ${BLAZERBOT_PACKAGE_NAME})/urdf/macros/material.xacro" />
    <xacro:include filename="$(find ${BLAZERBOT_PACKAGE_NAME})/urdf/macros/inertial.xacro" />
    <xacro:include filename="$(find ${BLAZERBOT_PACKAGE_NAME})/urdf/macros/wheels_diff_drive.xacro" />

    <!-- Specs -->
    <xacro:property name="chassis_length" value="0.322" />
    <xacro:property name="chassis_width" value="0.220" />
    <xacro:property name="chassis_height" value="0.12" />
    <xacro:property name="chassis_mass" value="4.8" />

    <xacro:property name="ground_clearance" value="0.024" />
    <xacro:property name="wheelbase" value="0.200" />
    <xacro:property name="track_width" value="0.175" />

    <xacro:property name="wheel_radius" value="0.055" />
    <xacro:property name="wheel_width" value="0.035" />
    <xacro:property name="wheel_mass" value="0.30" />

    <!-- base_footprint: ground-plane projection, required by Nav2/AMCL/SLAM -->
    <link name="base_footprint" />

    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_link" />
        <child link="base_footprint" />
        <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0" />
    </joint>

    <!-- base_link at wheel center plane -->
    <link name="base_link" />

    <xacro:property name="chassis_z_from_base"
        value="${ground_clearance + chassis_height/2 - wheel_radius}" />

    <joint name="chassis_joint" type="fixed">
        <parent link="base_link" />
        <child link="chassis" />
        <origin xyz="0 0 ${chassis_z_from_base}" rpy="0 0 0" />
    </joint>

    <link name="chassis">
        <visual name="chassis_visual">
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="${chassis_length} ${chassis_width} ${chassis_height}" />
            </geometry>
            <material name="chassis_dark" />
        </visual>
        <collision name="chassis_collision">
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="${chassis_length} ${chassis_width} ${chassis_height}" />
            </geometry>
        </collision>
        <xacro:box_inertial prefix="chassis"
            mass="${chassis_mass}"
            x="${chassis_length}" y="${chassis_width}" z="${chassis_height}">
            <origin xyz="0 0 0" rpy="0 0 0" />
        </xacro:box_inertial>
    </link>

    <gazebo reference="chassis">
        <material>Gazebo/Black</material>
    </gazebo>

    <xacro:diff_drive_wheels
        parent_link="base_link"
        wheel_radius="${wheel_radius}"
        wheel_width="${wheel_width}"
        wheel_mass="${wheel_mass}"
        wheelbase="${wheelbase}"
        track_width="${track_width}" />

</robot>